<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. 상단 헤더 영역 -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 탭 영역 (개인 운동 / PT) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_tab_bg"
            android:padding="4dp">
            <TextView
                android:id="@+id/tv_tab_personal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개인 운동"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/shape_tab_selected"
                android:textColor="@android:color/white" />
            <TextView
                android:id="@+id/tv_tab_pt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PT"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textColor="#B1B8C0" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="26.04.09"
            android:textSize="18sp"
            android:textColor="#B1B8C0"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/folder4_close" />
    </LinearLayout>

    <!-- 2. 중앙 스크롤 영역 (운동 리스트) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/layout_timer_bar"> <!-- 수정됨: app:layout_constraintBottom_toTopOf -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_workout_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_workout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_button_light_gray"
                android:text="+ 운동 추가하기"
                android:textColor="#2D3A4B" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 3. 하단 고정 타이머 바 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_timer_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/shape_timer_bar_bg"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"> <!-- 수정됨: app:layout_constraintBottom_toBottomOf -->

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:12:43"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btn_pause"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/pause"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_finish_workout" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_finish_workout"
            android:layout_width="100dp"
            android:layout_height="45dp"
            android:text="운동 마치기"
            android:background="@drawable/shape_button_light_gray"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>